{# Brand lockup, shared by both header variants and the footer.
   Renders the SVG logo from site.logo when set, else the DM Serif wordmark.
   The horizontal logo carries navy text, so callers on a navy ground pass
   forceWordmark=true to render the reversed serif wordmark instead.
   Callers may also set logoClass / wordmarkClass before including. #}
{% set logoClass = logoClass or "site-logo" %}
{% set wordmarkClass = wordmarkClass or "brand__wordmark" %}
<a class="brand" href="/" aria-label="{{ site.name }}, home">
  {% if site.logo and site.logo.url and not forceWordmark %}
    <img
      class="{{ logoClass }}"
      src="{{ site.logo.url }}"
      alt="{{ site.logo.alt }}"
      width="104"
      height="48"
    />
  {% else %}
    <span class="{{ wordmarkClass }}">{{ site.name }}</span>
  {% endif %}
</a>
