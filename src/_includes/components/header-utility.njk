{# Slim navy utility strip, shared by both header variants via the dispatcher.
   Surfaces what a person in distress wants first: location, the access
   promise, and a tap-to-call phone number. Not sticky; it scrolls away and
   lets the main header pin to the top on its own. Facts come from site.json:
   nap (locality, region, telephone), and access.seenWithin. #}
<div class="utility-bar">
  <div class="container utility-bar__inner">
    <ul class="utility-bar__list">
      <li class="utility-bar__item utility-bar__item--place">
        <svg class="utility-bar__icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 21s-6.5-5.4-6.5-10.5A6.5 6.5 0 0 1 12 4a6.5 6.5 0 0 1 6.5 6.5C18.5 15.6 12 21 12 21Z" />
          <circle cx="12" cy="10.5" r="2.25" />
        </svg>
        <span>{{ site.nap.addressLocality }}, {{ site.nap.addressRegion }}</span>
      </li>

      <li class="utility-bar__item utility-bar__item--access">
        <svg class="utility-bar__icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="8.5" />
          <path d="M12 7.5V12l3 2" />
        </svg>
        <span>{{ site.access.seenWithin }}</span>
      </li>

      <li class="utility-bar__item utility-bar__item--phone">
        <a href="tel:{{ site.nap.telephoneHref }}">
          <svg class="utility-bar__icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M6.5 4h3l1.4 3.6-2 1.4a12 12 0 0 0 5.6 5.6l1.4-2 3.6 1.4v3a1.5 1.5 0 0 1-1.6 1.5A15.5 15.5 0 0 1 5 6.6 1.5 1.5 0 0 1 6.5 4Z" />
          </svg>
          <span>{{ site.nap.telephone }}</span>
        </a>
      </li>
    </ul>
  </div>
</div>
